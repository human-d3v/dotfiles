set number
set relativenumber
set tabstop=2
set termguicolors
set signcolumn="yes"
set scrolloff=8
set colorcolumn=80
set updatetime=50
colorscheme desert
hi Normal ctermbg=NONE guibg=NONE
hi NonText ctermbg=NONE guibg=NONE
hi LineNr ctermbg=NONE guibg=NONE
hi Folded ctermbg=NONE guibg=NONE
hi EndOfBuffer ctermbg=NONE guibg=NONE
